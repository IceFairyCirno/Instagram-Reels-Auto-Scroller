{
  "manifest_version": 3,
  "name": "Instagram Reels Auto-Scroller",
  "version": "1.3.0",
  "description": "Automatically scrolls to the next Instagram Reel when the current one finishes",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "*://www.instagram.com/reels",
    "*://www.instagram.com/reels/*",
    "*://www.instagram.com/reel",
    "*://www.instagram.com/reel/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.instagram.com/reels",
        "*://www.instagram.com/reels/*",
        "*://www.instagram.com/reel",
        "*://www.instagram.com/reel/*"
      ],
      "js": ["content-script.js"],
      "css": ["content-style.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
